---
import { testimonials } from '../data/testimonials';
---

<section class="py-20 bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Heading -->
    <div class="text-center mb-14">
      <span class="text-primary text-sm font-semibold uppercase tracking-widest">Recenzije</span>
      <h2 class="font-heading text-3xl sm:text-4xl text-secondary font-bold mt-2 mb-4">Što kažu naši klijenti</h2>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.slice(0, 3).map((t) => (
        <div class="bg-card border border-border rounded-xl p-6 hover:shadow-md transition-shadow">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-accent">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-foreground-light leading-relaxed mb-6 text-sm">
            &ldquo;{t.text}&rdquo;
          </blockquote>

          <!-- Author -->
          <div class="border-t border-border pt-4">
            <p class="font-semibold text-secondary">{t.name}</p>
            <p class="text-foreground-light text-sm">{t.location} &middot; {t.service}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
