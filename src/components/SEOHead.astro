---
import { BUSINESS } from '../data/business-info';
import type { SEOProps } from '../lib/seo';
import { getCanonicalUrl, generateLLMMetaTags } from '../lib/seo';

interface Props extends SEOProps {
  structuredData?: object | object[];
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.png',
  ogType = 'website',
  article,
  noindex = false,
  structuredData,
} = Astro.props;

const fullTitle = title.includes(BUSINESS.siteName)
  ? title
  : `${title} | ${BUSINESS.siteName}`;

const canonicalUrl = canonical || getCanonicalUrl(Astro.url.pathname);
const ogImageUrl = ogImage.startsWith('http')
  ? ogImage
  : `${BUSINESS.siteUrl}${ogImage}`;

const llmMeta = generateLLMMetaTags({
  citationSnippet: `${BUSINESS.name} nudi stolarske usluge u Zagorju i Zagrebu. ${BUSINESS.experienceYears} godina iskustva u izradi kuhinja, namještaja, vrata, prozora i stepenica po mjeri. ${BUSINESS.address.city}, ${BUSINESS.address.region}.`,
  quickFacts: [
    `${BUSINESS.experienceYears} godina iskustva`,
    '8 vrsta usluga',
    `${BUSINESS.address.city}, Zagorje`,
    'Besplatna procjena',
  ],
});

const schemas = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!-- Primary Meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex,follow" />}
{!noindex && <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="hr_HR" />
<meta property="og:site_name" content={BUSINESS.siteName} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Article meta (for blog posts) -->
{article?.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
{article?.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
{article?.author && <meta property="article:author" content={article.author} />}

<!-- LLM/AI Crawler Meta Tags -->
{Object.entries(llmMeta).map(([key, value]) => (
  <meta name={key} content={value} />
))}

<!-- Structured Data -->
{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
