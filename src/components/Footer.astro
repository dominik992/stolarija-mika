---
import { BUSINESS } from '../data/business-info';
import { services } from '../data/services';

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary text-white/90">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- About -->
      <div>
        <img src={`${base}logo.svg`} alt={BUSINESS.name} class="h-14 w-auto mb-4 brightness-0 invert opacity-90" />
        <p class="text-white/70 text-sm leading-relaxed">
          Stolarski obrt s {BUSINESS.experienceYears} godina iskustva u izradi kvalitetnog drvenog namještaja, kuhinja, vrata, prozora i stepenica po mjeri.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-accent font-heading text-lg mb-4">Navigacija</h3>
        <ul class="space-y-2">
          <li><a href={base} class="text-white/70 hover:text-white text-sm transition-colors no-underline">Početna</a></li>
          <li><a href={`${base}o-nama`} class="text-white/70 hover:text-white text-sm transition-colors no-underline">O nama</a></li>
          <li><a href={`${base}usluge`} class="text-white/70 hover:text-white text-sm transition-colors no-underline">Usluge</a></li>
          <li><a href={`${base}galerija`} class="text-white/70 hover:text-white text-sm transition-colors no-underline">Galerija</a></li>
          <li><a href={`${base}blog`} class="text-white/70 hover:text-white text-sm transition-colors no-underline">Blog</a></li>
          <li><a href={`${base}kontakt`} class="text-white/70 hover:text-white text-sm transition-colors no-underline">Kontakt</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-accent font-heading text-lg mb-4">Usluge</h3>
        <ul class="space-y-2">
          {services.slice(0, 6).map((service) => (
            <li>
              <a href={`${base}usluge/${service.slug}`} class="text-white/70 hover:text-white text-sm transition-colors no-underline">
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-accent font-heading text-lg mb-4">Kontakt</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 text-accent"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-white/70 text-sm">{BUSINESS.address.street}<br />{BUSINESS.address.postalCode} {BUSINESS.address.city}</span>
          </li>
          <li>
            <a href={`tel:${BUSINESS.phone}`} class="flex items-center gap-2 text-white/70 hover:text-white text-sm transition-colors no-underline">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {BUSINESS.phoneDisplay}
            </a>
          </li>
          <li>
            <a href={`mailto:${BUSINESS.email}`} class="flex items-center gap-2 text-white/70 hover:text-white text-sm transition-colors no-underline">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              {BUSINESS.email}
            </a>
          </li>
          <li class="text-white/70 text-sm pt-2">
            <p>{BUSINESS.workingHours.weekdays}</p>
            <p>{BUSINESS.workingHours.saturday}</p>
            <p>{BUSINESS.workingHours.sunday}</p>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/50 text-sm">
        &copy; {currentYear} {BUSINESS.name}. Sva prava pridržana.
      </p>
      <p class="text-white/50 text-xs">
        {BUSINESS.address.street}, {BUSINESS.address.postalCode} {BUSINESS.address.city}
      </p>
    </div>
  </div>
</footer>
