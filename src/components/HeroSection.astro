---
import { BUSINESS } from '../data/business-info';

const base = import.meta.env.BASE_URL;
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden">
  <!-- Background with image and heavy overlay for text readability -->
  <div class="absolute inset-0">
    <img src={`${base}images/hero/workshop.png`} alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/75 to-black/55"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="max-w-2xl">
      <!-- Accent line -->
      <div class="w-16 h-1 bg-accent mb-8"></div>

      <!-- Heading -->
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-[3.5rem] font-bold leading-[1.15] mb-6">
        <span class="block text-white text-[0.65em] font-body font-semibold uppercase tracking-[0.2em] mb-3" style="text-shadow: 0 1px 10px rgba(0,0,0,0.5);">Stolarski obrt</span>
        <span class="block text-white" style="text-shadow: 0 2px 30px rgba(0,0,0,0.8);">S tradicijom i</span>
        <span class="block text-accent">ljubavlju prema drvu</span>
      </h1>

      <!-- Description -->
      <p class="text-lg text-white/90 leading-relaxed mb-10 max-w-lg" style="text-shadow: 0 1px 8px rgba(0,0,0,0.3);">
        Kuhinje, namještaj, vrata, prozori i stepenice po mjeri — sve izrađeno ručno od kvalitetnog drva. Radimo po cijeloj Hrvatskoj.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 mb-10">
        <a
          href={`${base}galerija`}
          class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-light text-secondary px-8 py-4 rounded-lg font-semibold text-lg transition-colors no-underline"
        >
          Pogledajte naše radove
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href={`${base}kontakt`}
          class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white border border-white/30 px-8 py-4 rounded-lg font-semibold text-lg transition-colors no-underline backdrop-blur-sm"
        >
          Zatražite ponudu
        </a>
      </div>

      <!-- Phone + experience -->
      <div class="flex flex-col sm:flex-row sm:items-center gap-6 text-white/80 text-sm">
        <a href={`tel:${BUSINESS.phone}`} class="flex items-center gap-2 no-underline text-white/80 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span class="font-medium">{BUSINESS.phoneDisplay}</span>
        </a>
        <span class="hidden sm:block w-px h-4 bg-white/30"></span>
        <span>{BUSINESS.experienceYears}+ godina iskustva</span>
        <span class="hidden sm:block w-px h-4 bg-white/30"></span>
        <span>Cijela Hrvatska</span>
      </div>
    </div>
  </div>
</section>
