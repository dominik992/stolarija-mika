---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import { BUSINESS } from '../data/business-info';

const values = [
  {
    title: 'Tradicija',
    description: 'Njegujemo zagorsku stolarsku tradiciju i stoljetne tehnike obrade drva koje prenosimo iz generacije u generaciju.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2 2 2 0 0 0-2 2v2a2 2 0 0 0 2 2Z"/><path d="m18.4 12.4-1.4-1.4a2 2 0 0 0-2.8 0l-1.4 1.4a2 2 0 0 0 0 2.8l1.4 1.4a2 2 0 0 0 2.8 0l1.4-1.4a2 2 0 0 0 0-2.8Z"/><path d="M8 18H6a2 2 0 0 1-2-2 2 2 0 0 1 2-2h2a2 2 0 0 1 2 2 2 2 0 0 1-2 2Z"/><path d="M12 22v-2a2 2 0 0 0-2-2 2 2 0 0 0-2 2v2a2 2 0 0 0 2 2 2 2 0 0 0 2-2Z"/></svg>`,
  },
  {
    title: 'Kvaliteta',
    description: 'Koristimo samo najkvalitetnije vrste drva i provjerene materijale. Svaki proizvod prolazi strogu kontrolu kvalitete.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 L15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2z"/></svg>`,
  },
  {
    title: 'Preciznost',
    description: 'Svaki detalj je bitan. Radimo s milimetarskom preciznošću kako bi svaki komad savršeno pristajao u vaš prostor.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  },
  {
    title: 'Povjerenje',
    description: 'Stotine zadovoljnih klijenata i preporuke koje govore same za sebe. Gradimo dugotrajne odnose temeljene na povjerenju.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];
---

<BaseLayout
  title="O nama | Stolarija Mika - 25 godina tradicije u Zagorju"
  description="Upoznajte Stolariju Mika - stolarski obrt Nikole Blageca s 25 godina iskustva u izradi namještaja, kuhinja i stolarije. Donja Stubica, Krapinsko-zagorska županija."
>
  <!-- Hero -->
  <section class="py-16 sm:py-20 bg-muted">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'O nama' }]} />

      <div class="text-center max-w-3xl mx-auto">
        <span class="text-primary text-sm font-semibold uppercase tracking-widest">Naša priča</span>
        <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl text-secondary font-bold mt-2 mb-6">
          O Stolariji Mika
        </h1>
        <p class="text-foreground-light text-lg">
          Više od dva desetljeća posvećenosti drvu, kvaliteti i zadovoljstvu svakoga klijenta.
        </p>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="py-16 sm:py-20 bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <div class="lg:col-span-3">
          <h2 class="font-heading text-2xl sm:text-3xl text-secondary font-bold mb-6">
            Priča o Miki i ljubavi prema drvu
          </h2>

          <div class="space-y-5 text-foreground-light leading-relaxed">
            <p>
              Nikola Blagec, poznat svima kao <strong class="text-secondary">Mika</strong>, odrastao je u srcu Hrvatskog zagorja okružen šumama i drvenim kućama. Još kao dječak fasciniran je bio mirisom svježe obrađenog drva u radionici svoga djeda. Ta rana strast pretvorila se u životni poziv - 1999. godine Mika osniva vlastiti stolarski obrt u Donjoj Stubici, s jednostavnom vizijom: izrađivati kvalitetne proizvode od drva koji će služiti generacijama.
            </p>
            <p>
              Kroz više od <strong class="text-secondary">25 godina rada</strong>, Stolarija Mika izrasla je u sinonim za pouzdanu i kvalitetnu stolariju u Krapinsko-zagorskoj županiji i šire. Mika je samouki majstor koji je svoje znanje stekao kroz godine predanog rada, stalnog usavršavanja i učenja od starijih majstora. Svaki projekt doživljava osobno - od prvih razgovora s klijentom, preko pažljivog odabira drva, sve do zadnjeg brušenja i premaza. Taj osobni pristup je ono što Stolariju Mika čini posebnom.
            </p>
            <p>
              Danas Stolarija Mika nudi širok spektar stolarskih usluga - od izrade kuhinja i namještaja po mjeri, preko drvenih vrata, prozora i stepenica, do pergola i restauracije starog namještaja. Bez obzira radi li se o modernom minimalističkom dizajnu ili tradicionalnom zagorskom stilu, Mika pristupa svakom poslu s jednakom strašću i posvećenošću. Jer za njega stolarija nije samo posao - to je način života.
            </p>
          </div>
        </div>

        <div class="lg:col-span-2">
          <div class="bg-gradient-to-br from-primary/10 to-secondary/20 rounded-xl p-8 text-center">
            <div class="w-24 h-24 mx-auto bg-primary/10 rounded-full flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            </div>
            <h3 class="font-heading text-xl text-secondary font-bold mb-2">Nikola Blagec - Mika</h3>
            <p class="text-foreground-light text-sm mb-6">Vlasnik i majstor stolar</p>

            <div class="space-y-4 text-left">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                </div>
                <div>
                  <p class="text-xs text-foreground-light">Osnovan</p>
                  <p class="text-sm font-semibold text-secondary">{BUSINESS.foundedYear}. godine</p>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                  <p class="text-xs text-foreground-light">Iskustvo</p>
                  <p class="text-sm font-semibold text-secondary">{BUSINESS.experienceYears}+ godina</p>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <p class="text-xs text-foreground-light">Lokacija</p>
                  <p class="text-sm font-semibold text-secondary">{BUSINESS.address.city}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 sm:py-20 bg-muted">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-primary text-sm font-semibold uppercase tracking-widest">Naše vrijednosti</span>
        <h2 class="font-heading text-3xl sm:text-4xl text-secondary font-bold mt-2 mb-4">
          Na čemu gradimo
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value) => (
          <div class="bg-card border border-border rounded-xl p-6 text-center hover:shadow-lg transition-shadow duration-300">
            <div class="w-16 h-16 mx-auto bg-primary/10 rounded-xl flex items-center justify-center mb-4 text-primary">
              <Fragment set:html={value.icon} />
            </div>
            <h3 class="font-heading text-xl text-secondary font-bold mb-2">{value.title}</h3>
            <p class="text-foreground-light text-sm leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Workshop -->
  <section class="py-16 sm:py-20 bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-primary text-sm font-semibold uppercase tracking-widest">Radionica</span>
        <h2 class="font-heading text-3xl sm:text-4xl text-secondary font-bold mt-2 mb-4">
          Naša radionica u Donjoj Podgori
        </h2>
      </div>

      <div class="bg-card border border-border rounded-xl p-8 sm:p-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div class="rounded-xl overflow-hidden aspect-[4/3]">
            <img src="/images/hero/workshop.png" alt="Radionica Stolarije Mika" class="w-full h-full object-cover" />
          </div>

          <div>
            <p class="text-foreground-light leading-relaxed mb-4">
              Naša radionica smještena je na adresi <strong class="text-secondary">{BUSINESS.address.street}</strong> u mirnom zagorskom okruženju, opremljena profesionalnim alatima i strojevima za obradu drva. Ovdje nastaje svaki komad namještaja - od prvog reza do završne obrade.
            </p>
            <p class="text-foreground-light leading-relaxed mb-6">
              U radionici uvijek imamo zalihu kvalitetnog drva - hrasta, bukve, jasena i oraha - spremnog za vaš sljedeći projekt. Pozivamo vas da nas posjetite, razgledate radionicu i osobno se uvjerite u kvalitetu našeg rada.
            </p>
            <a
              href="/kontakt"
              class="inline-flex items-center gap-2 text-primary font-semibold hover:text-primary-dark transition-colors no-underline"
            >
              Posjetite nas
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
